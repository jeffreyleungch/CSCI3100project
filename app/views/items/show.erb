<h1>Item Detail View</h1>

<% if params['notice'] && !params['notice'].empty? %>
  <p style="color: green;"><%= h(params['notice']) %></p>
<% end %>

<% if @bid_errors && !@bid_errors.empty? %>
  <div style="color: red;">
    <p>Could not place bid:</p>
    <ul>
      <% @bid_errors.each do |message| %>
        <li><%= h(message) %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<div class="item-detail">
  <h2><%= h(@item.name) %></h2>
  <p>Description: <%= h(@item.description) %></p>
  <p>Price: <%= number_to_currency(@item.price) %></p>
  <p>Category: <%= h(@item.category) %></p>
  <p>Available: <%= @item.available ? 'Yes' : 'No' %></p>
  <p>Current Highest Bid: <%= @highest_bid ? number_to_currency(@highest_bid.amount) : 'No bids yet' %></p>
</div>

<section style="margin-bottom: 1rem;">
  <h2>Place a Bid</h2>
  <form action="/items/<%= @item.id %>/bids" method="post">
    <div>
      <label for="bidder_name">Your Name</label>
      <input id="bidder_name" name="bid[bidder_name]" type="text" required>
    </div>
    <div>
      <label for="bid_amount">Bid Amount</label>
      <input id="bid_amount" name="bid[amount]" type="number" step="0.01" min="0.01" required>
    </div>
    <button type="submit">Place Bid</button>
  </form>
</section>

<section>
  <h2>Bid History</h2>
  <% if @bids && !@bids.empty? %>
    <table>
      <thead>
        <tr>
          <th>Bidder</th>
          <th>Amount</th>
          <th>Time</th>
        </tr>
      </thead>
      <tbody>
        <% @bids.each do |bid| %>
          <tr>
            <td><%= h(bid.bidder_name) %></td>
            <td><%= number_to_currency(bid.amount) %></td>
            <td><%= format_datetime(bid.created_at) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p>No bids yet.</p>
  <% end %>
</section>

<a href="/items">Back to items list</a>