<h1>Item Detail View</h1>

<div class="item-detail">
  <h2><%= @item.name %></h2>
  <p>Description: <%= @item.description %></p>
  <p>Price: $<%= @item.price %></p>
  <p>Category: <%= @item.category %></p>
  <p>Available: <%= @item.available ? 'Yes' : 'No' %></p>
</div>

<a href="/items">Back to items list</a>